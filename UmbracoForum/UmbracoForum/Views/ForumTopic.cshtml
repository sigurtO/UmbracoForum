@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ForumTopic>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using UmbracoForum.Models
@using UmbracoForum.Controllers
@{
	Layout = "master.cshtml";
	// Get all threads, ordered by newest first
	var threads = Model.Children<ForumThread>()?.OrderByDescending(x => x.CreateDate);
}

<a href="/">&larr; Back to Forum Home</a>

<div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1>@Model.TopicTitle</h1>
        <p>@Model.TopicDescription</p>
    </div>
    
    <button onclick="toggleThreadForm()" style="padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
        + Create Thread
    </button>
</div>

@await Html.PartialAsync("Partials/_CreateThreadForm", new CreateThreadViewModel { TopicId = Model.Id })

<hr />

<div class="thread-list">


<div class="thread-list">
    @if (threads != null && threads.Any())
    {
        <ul>
            @foreach (var thread in threads)
            {
                <li style="margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    <h3 style="margin: 0 0 5px 0;">
                        <a href="@thread.Url()" style="text-decoration: none; color: #0056b3;">@thread.ThreadTitle</a>
                    </h3>
                    <small style="color: #666;">Posted on: @thread.CreateDate.ToString("MMM dd, yyyy")</small>
                </li>
            }
        </ul>
    }
    else
    {
        <p>There are no threads in this topic yet. Be the first to start a discussion!</p>
    }
</div>

<script>
    function toggleThreadForm() {
        var formWrapper = document.getElementById("create-thread-wrapper");
        if (formWrapper.style.display === "none") {
            formWrapper.style.display = "block";
        } else {
            formWrapper.style.display = "none";
        }
    }

    // Optional UX trick: If the server returns an ErrorMessage, keep the form open on page load!
    @if(TempData["ErrorMessage"] != null)
    {
        <text>
            document.getElementById("create-thread-wrapper").style.display = "block";
        </text>
    }
</script>