@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ForumTopic>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using UmbracoForum.Models
@using UmbracoForum.Controllers
@{
	Layout = "master.cshtml";
	// Get all threads, ordered by newest first
	var threads = Model.Children<ForumThread>()?.OrderByDescending(x => x.CreateDate);
}

<a href="/">&larr; Back to Forum Home</a>

<h1>@Model.TopicTitle</h1>
<p>@Model.TopicDescription</p>

<hr />

<div class="create-thread-box" style="background: #e9ecef; padding: 20px; border-radius: 5px; margin-bottom: 30px;">
    <h3>Start a New Discussion</h3>
    
    @if (TempData["ErrorMessage"] != null)
    {
        <p style="color: red;">@TempData["ErrorMessage"]</p>
    }

    @using (Html.BeginUmbracoForm<ForumController>(nameof(ForumController.SubmitNewThread)))
    {
        <input type="hidden" name="TopicId" value="@Model.Id" />

        <div style="margin-bottom: 10px;">
            <label>Thread Title:</label><br />
            <input type="text" name="Title" required style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 10px;">
            <label>Your Message:</label><br />
            <textarea name="Content" rows="5" required style="width: 100%; padding: 8px;"></textarea>
        </div>

        <button type="submit" style="padding: 10px 20px; background: #0056b3; color: white; border: none; border-radius: 4px; cursor: pointer;">
            Post Thread
        </button>
    }
</div>

<div class="thread-list">
    @if (threads != null && threads.Any())
    {
        <ul>
            @foreach (var thread in threads)
            {
                <li>
                    <a href="@thread.Url()">@thread.ThreadTitle</a>
                    <br />
                    <small>Posted: @thread.CreateDate.ToString("MMM dd, yyyy")</small>
                </li>
            }
        </ul>
    }
    else
    {
        <p>There are no threads in this topic yet. Be the first to start a discussion!</p>
    }
</div>